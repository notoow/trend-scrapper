# === HAIST Issue Tracker ===
# API 키를 아래에 입력하세요.
# 이 파일을 .env로 복사한 뒤 값을 채워주세요: cp .env.example .env

# Google Gemini API (메인 AI 요약)
# 발급: https://aistudio.google.com/
GEMINI_API_KEY=

# Groq API (백업 AI 요약)
# 발급: https://console.groq.com/
GROQ_API_KEY=

# Google Sheets ID (스프레드시트 URL에서 추출)
# 예: https://docs.google.com/spreadsheets/d/{이_부분}/edit
GOOGLE_SHEETS_ID=

# Google Service Account JSON (Base64 인코딩)
# Google Cloud Console에서 서비스 계정 생성 후 JSON 키 다운로드
# GitHub Secrets에는 JSON 파일 전체 내용을 넣어주세요
GOOGLE_SERVICE_ACCOUNT_JSON=

# NewsAPI (영문 뉴스 수집)
# 발급: https://newsapi.org/
NEWSAPI_KEY=
